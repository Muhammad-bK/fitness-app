{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173,
      "cwd": "frontend"
    },
    {
      "name": "backend",
      "runtimeExecutable": "backend/venv/Scripts/python.exe",
      "runtimeArgs": ["backend/manage.py", "runserver", "8000"],
      "port": 8000,
      "env": {
        "DJANGO_SETTINGS_MODULE": "config.settings.dev"
      }
    }
  ]
}
